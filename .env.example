# Copia este archivo como .env.local y llena los valores.
# En Vercel, carga estas mismas variables en Settings → Environment Variables
# marcando los tres entornos (Production, Preview, Development).

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Inventa una cadena larga y aleatoria. Debe ser LA MISMA en ambas variables.
# Protege el botón "Publicar cambios" del admin.
REVALIDATE_SECRET=
NEXT_PUBLIC_REVALIDATE_SECRET=
