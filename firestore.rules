rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /variants/{sku} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
    match /movimientos/{movId} {
      allow read, write: if request.auth != null;
    }
  }
}
